# .env.example
# Пример конфигурации для бота Пинки Пай
# Скопируйте этот файл в .env и заполните своими данными
#
# Автор: MADAO81
# Версия: 2.0

# ============================================
# TELEGRAM (обязательно)
# ============================================
# Токен бота, полученный от @BotFather в Telegram
# Как получить: напишите @BotFather → /newbot → следуйте инструкциям
TELEGRAM_TOKEN=ваш_токен_бота_от_BotFather

# ============================================
# OPENAI (обязательно)
# ============================================
# API ключ OpenAI для доступа к GPT-4-turbo, Vision и Whisper
# Как получить: https://platform.openai.com/api-keys
OPENAI_API_KEY=ваш_api_ключ_openai

# Модель OpenAI (по умолчанию gpt-4-turbo)
# Доступные варианты: gpt-4-turbo, gpt-4, gpt-3.5-turbo
OPENAI_MODEL=gpt-4-turbo

# Максимальное количество токенов в ответе (по умолчанию 1000)
OPENAI_MAX_TOKENS=1000

# Температура генерации (0.0 - 2.0, по умолчанию 0.85)
# Выше = более креативные ответы, ниже = более предсказуемые
OPENAI_TEMPERATURE=0.85

# ============================================
# ЯНДЕКС ПОГОДА (обязательно)
# ============================================
# API ключ для доступа к Яндекс Погоде
# Как получить: https://yandex.ru/dev/weather/
YANDEX_WEATHER_API_KEY=ваш_api_ключ_яндекс_погоды

# Координаты Боровского района Калужской области
# (по умолчанию: 55.2067, 36.6550)
YANDEX_WEATHER_LAT=55.2067
YANDEX_WEATHER_LON=36.6550

# ============================================
# НАСТРОЙКИ БОТА (опционально)
# ============================================
# Рабочее время бота (по умолчанию 9:00 - 20:00)
# Формат: часы от 0 до 23
WORK_START_HOUR=9
WORK_END_HOUR=20

# Вероятность грустного настроения при плохой погоде (по умолчанию 0.2 = 20%)
# Диапазон: 0.0 - 1.0
SAD_PROBABILITY=0.2

# Срок хранения истории диалогов в днях (по умолчанию 30)
CONTEXT_EXPIRE_DAYS=30

# Время ежедневной отправки рецепта (по умолчанию 12:00)
# Формат: ЧЧ:ММ
RECIPE_SEND_TIME=12:00

# URL для парсинга рецептов (по умолчанию andychef.ru)
RECIPE_URL=https://andychef.ru

# ============================================
# ПУТИ (опционально)
# ============================================
# Пути для хранения данных, логов и аудио
# По умолчанию создаются в корне проекта
# DATA_DIR=./data
# LOGS_DIR=./logs
# AUDIO_DIR=./data/audio
